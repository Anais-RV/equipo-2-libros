{
  "name": "equipo-2-libros-backend",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "backend",
  "workspaceFolder": "/app",
  "runServices": [
    "backend",
    "frontend"
  ],
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "customizations": {
    "vscode": {
      "settings": {
        "python.analysis.extraPaths": [
          "/app",
          "/app/backend"
        ]
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
